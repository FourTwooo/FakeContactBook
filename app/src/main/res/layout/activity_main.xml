<!--                                android:layout_height="wrap_content"-->
<!--                                android:layout_marginTop="4dp"-->
<!--                                android:text="方案、规则、扩展能力分开管理。后续接 API、手机号生成器、社交平台资料都不会挤在一页。" />-->

<!--                            <com.google.android.material.button.MaterialButton-->
<!--                                android:id="@+id/btnOpenProfiles"-->
<!--                                android:layout_width="match_parent"-->
<!--                                android:layout_height="48dp"-->
<!--                                android:layout_marginTop="14dp"-->
<!--                                android:text="管理通讯录方案" />-->

<!--                            <com.google.android.material.button.MaterialButton-->
<!--                                android:id="@+id/btnOpenApps"-->
<!--                                style="?attr/materialButtonOutlinedStyle"-->
<!--                                android:layout_width="match_parent"-->
<!--                                android:layout_height="48dp"-->
<!--                                android:layout_marginTop="10dp"-->
<!--                                android:text="管理指定 App 规则" />-->

<!--                            <com.google.android.material.button.MaterialButton-->
<!--                                android:id="@+id/btnOpenExtensions"-->
<!--                                style="?attr/materialButtonOutlinedStyle"-->
<!--                                android:layout_width="match_parent"-->
<!--                                android:layout_height="48dp"-->
<!--                                android:layout_marginTop="10dp"-->
<!--                                android:text="扩展能力 / API / 生成器" />-->
<!--                        </LinearLayout>-->
<!--                    </com.google.android.material.card.MaterialCardView>-->
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- 通用列表页：方案页 / 应用规则页共用 -->
            <LinearLayout
                android:id="@+id/pageList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardBackgroundColor="@color/fc_surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/sectionTitle"
                            style="@style/Text.Title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="列表" />

                        <TextView
                            android:id="@+id/sectionSub"
                            style="@style/Text.Body"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="说明" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/searchLayout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="搜索"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/searchInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:imeOptions="actionSearch"
                                android:singleLine="true" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="96dp" />
            </LinearLayout>

            <!-- 扩展能力页 -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/pageExtensions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="96dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnContactQueryTester"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:text="通讯录查询测试器"
                        app:icon="@android:drawable/ic_menu_search" />

                    <!-- 社交资料提交 API -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/fc_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                style="@style/Text.Title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Content Provider API" />

                            <TextView
                                style="@style/Text.Body"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="第三方平台信息储存" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnApiGuide"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="12dp"
                                android:text="查看提交 API 说明" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- NanoHTTPD / 外部接入 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/fc_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                style="@style/Text.Title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="HTTP API" />

                            <TextView
                                style="@style/Text.Body"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="建议接口：GET /profiles、GET /profiles/{id}/contacts、POST /profiles/{id}/contacts、POST /social/upsert、POST /generator/phones。" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnHttpApi"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="12dp"
                                android:text="查看 / 启动 HTTP API" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 手机号生成器 -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:cardBackgroundColor="@color/fc_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                style="@style/Text.Title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="手机号生成器" />

                            <TextView
                                style="@style/Text.Body"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="https://github.com/FourTwooo/NumberGenerate" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnGeneratorGuide"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="12dp"
                                android:text="查看生成器" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </FrameLayout>

        <!-- 底部导航 -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/fc_surface"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/menu_main_bottom" />
    </LinearLayout>

    <!-- 全局悬浮按钮 -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="86dp"
        android:text="新建方案"
        app:icon="@android:drawable/ic_input_add" />
</FrameLayout>