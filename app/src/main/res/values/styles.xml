<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FakeContactBook" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fc_primary</item>
        <item name="colorPrimaryVariant">@color/fc_primary_dark</item>
        <item name="colorSecondary">@color/fc_secondary</item>

        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/fc_background</item>
        <item name="android:navigationBarColor">@color/fc_surface</item>
        <item name="android:windowBackground">@color/fc_background</item>

        <item name="materialButtonStyle">@style/Widget.FakeContactBook.Button</item>
        <item name="materialCardViewStyle">@style/Widget.FakeContactBook.Card</item>
    </style>

    <style name="Widget.FakeContactBook.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeColor">#E7EAF5</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.FakeContactBook.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">14dp</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="Text">
        <item name="android:fontFamily">sans</item>
        <item name="android:includeFontPadding">true</item>
    </style>

    <style name="Text.ScreenTitle" parent="@style/Text">
        <item name="android:textColor">@color/fc_text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.StatNumber" parent="@style/Text">
        <item name="android:textColor">@color/fc_text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Title" parent="@style/Text">
        <item name="android:textColor">@color/fc_text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Body" parent="@style/Text">
        <item name="android:textColor">@color/fc_text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>